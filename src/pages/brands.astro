<html>
<head>
<title>Our Brands – Mikey Markets LLC</title>
<style>
body { font-family: Arial, sans-serif; margin: 0; background: #fff; color: #222;}
.brand-list { margin: 2rem auto; max-width: 600px; }
.brand-list h2 { color: #06b6d4; margin-top: 1.5rem; }
.brand-card { border-left: 5px solid #06b6d4; background: #f7fafc; margin: 1.7rem 0; padding: 1rem 1.7rem; border-radius: 8px; }
a { color: #222; text-decoration: underline dotted; }
</style>
</head>
<body>
<nav>
<a href="/">Home</a> |
<a href="/brands">Brands</a> |
<a href="/about">About</a> |
<a href="/contact">Contact</a> |
<a href="/privacy">Privacy</a>
</nav>
<div class="brand-list">
<h1>Our Brands</h1>
{brands.map(b => (
<div class="brand-card" style={{ borderColor: b.color }}>
<a href={b.link} target="_blank"><h2>{b.name}</h2></a>
<p>{b.desc}</p>
</div>
))}
</div>
</body>
